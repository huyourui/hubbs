# 配置文件（包含敏感信息）
/data/config.php

# 安装锁定文件
/install.lock

# 上传文件目录
/uploads/images/*
/uploads/attachments/*
/uploads/avatars/*
!/uploads/images/.gitkeep
!/uploads/attachments/.gitkeep
!/uploads/avatars/.gitkeep

# 备份文件
*.bak
*.backup

# IDE 和编辑器
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# 日志文件
*.log
/logs/*
!/logs/.gitkeep

# 缓存文件
/cache/*
!/cache/.gitkeep

# Composer 依赖
/vendor/

# 测试相关
/tests/
/.phpunit.cache/
phpunit.xml
phpunit.xml.dist

# 临时文件
/tmp/*
!/tmp/.gitkeep

# 服务器环境特定文件
.user.ini
.htaccess
.well-known/

# 调试和测试文件
debug_header.php
debug_url.php
test.php
test_download.php

# 环境配置
.env
.env.local
.env.example

# Node.js
node_modules/
package.json
package-lock.json
yarn.lock

# 编辑器配置
.editorconfig

# 其他
*.tmp
*.temp
